# Exposes the Debian packaging data files from
# lldpd_1.0.16-1+deb12u1.debian.tar.xz (extracted at the repo root as
# debian/...). Consumed by //src/lldpd:BUILD.bazel genrules.

package(default_visibility = ["//visibility:public"])

exports_files([
    "debian/lldpd.default",
    "debian/lldpd.init.d",
    "debian/copyright",
    "debian/changelog",
    "debian/README.Debian",
    "debian/lldpd.lintian-overrides",
])
