module(
    name = "isc-dhcp",
    version = "4.4.3-P1-2",
)

bazel_dep(name = "bazel_skylib", version = "1.9.0")
bazel_dep(name = "rules_cc", version = "0.2.16")
bazel_dep(name = "platforms", version = "1.1.0")
bazel_dep(name = "sonic-build-infra", version = "0.0.0", repo_name = "sonic_build_infra")

ISC_DHCP_VERSION = "4.4.3-P1"

ISC_DHCP_PATCHES = [
    "//:patch/0001-Bugfix-Don-t-print-log-messages-to-stderr-in-release.patch",
    "//:patch/0002-Customizable-Option-82-circuit-ID-and-remote-ID-fiel.patch",
    "//:patch/0003-Support-for-obtaining-name-of-physical-interface-tha.patch",
    "//:patch/0004-Support-for-loading-port-alias-map-file-to-replace-p.patch",
    # 0005 only edits debian/rules to add --enable-use-sockets; folded into copts here.
    "//:patch/0006-Bugfix-Ensure-HAVE_SO_BINDTODEVICE-has-a-chance-to-b.patch",
    "//:patch/0007-If-destination-of-BOOTREQUEST-is-directed-broadcast-.patch",
    "//:patch/0008-Don-t-skip-down-interfaces-when-discovering-interfac.patch",
    "//:patch/0009-Support-for-dual-tor-scenario.patch",
    "//:patch/0010-Bugfix-correctly-set-interface-netmask.patch",
    "//:patch/0011-dhcp-relay-Prevent-Buffer-Overrun.patch",
    "//:patch/0012-add-option-si-to-support-using-src-intf-ip-in-relay.patch",
    # 0013 (upstream ISC fix for agent-option buffer pointer logic) is already
    # applied by the cumulative effect of patches 0001-0012; the original
    # `stg import` flow detected and skipped it, but Bazel's
    # repository_ctx.patch is stricter, so we drop it from the list to avoid
    # a CONTENT_DOES_NOT_MATCH_TARGET error.
    # 0014 only edits debian/rules to enable parallel build.
    "//:patch/0015-option-to-set-primary-address-in-interface.patch",
    "//:patch/0016-Don-t-look-up-the-ifindex-for-fallback.patch",
    "//:patch/0017-Register-IO-obj-before-create-fd-watch.patch",
]

sonic_http_archive = use_repo_rule("@sonic_build_infra//sonic_http_archive:sonic_http_archive.bzl", "sonic_http_archive")

# Upstream isc-dhcp orig tarball. The vendored bind/bind.tar.gz inside this
# tarball is *not* used; we fetch BIND 9.11.36 separately below so its sources
# are visible to Bazel globs.
sonic_http_archive(
    name = "isc_dhcp_src",
    build_file_template = "//:isc-dhcp.BUILD",
    patches = ISC_DHCP_PATCHES,
    sha256 = "0ac416bb55997ca8632174fd10737fd61cdb8dba2752160a335775bc21dc73c7",
    strip_prefix = "dhcp-{}".format(ISC_DHCP_VERSION),
    urls = ["https://deb.debian.org/debian/pool/main/i/isc-dhcp/isc-dhcp_{}.orig.tar.gz".format(ISC_DHCP_VERSION)],
)

# Standalone BIND 9.11.36 source. Content is identical to the bind.tar.gz
# bundled inside isc-dhcp's orig tarball (verified 2026-05-07; only the srcid
# file differs). We fetch it separately so all C sources are reachable from a
# Bazel glob, instead of needing a genrule to untar bind/bind.tar.gz.
http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "isc_dhcp_bind_src",
    build_file = "//:bind.BUILD",
    sha256 = "c953fcb6703b395aaa53e65ff8b2869b69a5303dd60507cba2201305e1811681",
    strip_prefix = "bind-9.11.36",
    urls = ["https://ftp.isc.org/isc/bind9/9.11.36/bind-9.11.36.tar.gz"],
)
