# =============================================================================
# Generated headers: config.h, lib/config_paths.h, lib/version.h,
# lib/route_types.h, lib/vtysh_daemons.h
#
# Upstream FRR generates these from configure.ac via autoconf.  Rather than
# running ./configure inside Bazel we materialise the values ./configure WOULD
# emit on Debian trixie / glibc 2.41 / GCC 14, with the exact configure flag
# set from the SONiC-patched debian/rules:
#   --sbindir=/usr/lib/frr --with-vtysh-pager=/usr/bin/pager
#   --libdir=/usr/lib/<multiarch>/frr
#   --with-moduledir=/usr/lib/<multiarch>/frr/modules
#   --with-libpam --enable-doc --enable-doc-html --enable-snmp --enable-fpm
#   --enable-sharpd --disable-protobuf --disable-zeromq --enable-ospfapi
#   --enable-multipath=514 --enable-pcre2posix
#   --enable-user=frr --enable-group=frr --enable-vty-group=frrvty
#   --enable-configfile-mask=0640 --enable-logfile-mask=0640
#   (pkg.frr.nortrlib -> --disable-rpki; --disable-scripting; --disable-grpc)
#   patch 0016: --enable-multipath=514 + no --enable-bgp-vnc (VNC disabled)
# =============================================================================
