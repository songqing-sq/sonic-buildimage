# frr-pythontools scripts: reduce the shebang (first line) to a bare "#!" to
# match the Make baseline byte-for-byte. Upstream debian/rules does
# `sed -e '1c #!$(shell which $PYTHON)'` where $PYTHON expands empty in make's
# shell, leaving a bare "#!". These scripts are invoked as `python3 <script>`
# (frrcommon.sh), so the shebang is cosmetic; we replicate Make exactly.
[
    genrule(
        name = "{}_shebang".format(stem),
        srcs = [src],
        outs = ["gen/pythontools/{}".format(fname)],
        cmd = "sed '1s|^.*$$|#!|' $< > $@",
        visibility = ["//visibility:public"],
    )
    for stem, fname, src in [
        ("frr-reload_py", "frr-reload.py", "frr/tools/frr-reload.py"),
        ("generate_support_bundle_py", "generate_support_bundle.py", "frr/tools/generate_support_bundle.py"),
        ("frr_babeltrace_py", "frr_babeltrace.py", "frr/tools/frr_babeltrace.py"),
        ("ospfclient_py", "ospfclient.py", "frr/ospfclient/ospfclient.py"),
    ]
]

