        ":libfrr",
    ],
    dynamic_deps = [
        ":libfrr_shared",
    ],
    soversion = "0",
    version = "0.0.0",
    output_name = "libfrrospfapiclient",
    allow_undefined = True,
    visibility = ["//visibility:public"],
)

# =============================================================================
# Processed shell wrappers / integration files (autoconf @var@ substitution).
#
# The Make build renders tools/*.in via config.status; we reproduce the exact
# substituted output with sed.  Substitution values were derived by diffing the
# Make-shipped files against the .in templates:
#   @e_sbindir@=/usr/lib/frr  @e_frr_sysconfdir@=/etc/frr
#   @e_frr_runstatedir@=/var/run/frr  @e_bindir@=/usr/bin
#   @e_vtysh_bin@=/usr/bin/vtysh  @enable_user@=frr  @enable_group@=frr
#   @enable_vty_group@=frrvty  @enable_configfile_mask@=0640
#   @DFLT_NAME@=traditional  @TIMEOUT_MIN@=2
# =============================================================================
_FRR_SUBST_SED = (
    "sed " +
    "-e 's|@e_sbindir@|/usr/lib/frr|g' " +
    "-e 's|@e_frr_sysconfdir@|/etc/frr|g' " +
    "-e 's|@e_frr_runstatedir@|/var/run/frr|g' " +
    "-e 's|@e_bindir@|/usr/bin|g' " +
    "-e 's|@e_vtysh_bin@|/usr/bin/vtysh|g' " +
    "-e 's|@enable_user@|frr|g' " +
    "-e 's|@enable_group@|frr|g' " +
    "-e 's|@enable_vty_group@|frrvty|g' " +
    "-e 's|@enable_configfile_mask@|0640|g' " +
    "-e 's|@DFLT_NAME@|traditional|g' " +
    "-e 's|@TIMEOUT_MIN@|2|g' "
)

genrule(
    name = "frrcommon_sh_gen",
    srcs = ["frr/tools/frrcommon.sh.in"],
    outs = ["gen/frrcommon.sh"],
    cmd = _FRR_SUBST_SED + "$< > $@",
    visibility = ["//visibility:public"],
)

genrule(
    name = "frrinit_sh_gen",
    srcs = ["frr/tools/frrinit.sh.in"],
