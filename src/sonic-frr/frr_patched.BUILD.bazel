# lib/config_paths.h -- FRR 10.5.4 moved the runtime path macros out of
# config.h into a dedicated generated header (only libfrr + watchfrr include
# it).  MODULE_PATH / YANG_MODELS_PATH etc. mirror debian/rules'
# --libdir=/usr/lib/<multiarch>/frr + --with-moduledir + sbindir=/usr/lib/frr.
# The multiarch component is arch-specific, so emit via select() (Lesson 11 --
# no hardcoded x86_64-linux-gnu).
genrule(
    name = "config_paths_h_gen",
    outs = ["frr/lib/config_paths.h"],
    cmd = select({
        "@platforms//cpu:aarch64": "MULTIARCH=aarch64-linux-gnu",
        "//conditions:default": "MULTIARCH=x86_64-linux-gnu",
    }) + r""" ; cat > $@ <<EOF
/* Bazel-emitted lib/config_paths.h (autoconf equivalent). */
#define FRR_RUNSTATE_PATH	"/run/frr"
#define FRR_LIBSTATE_PATH	"/var/lib/frr"
#define YANG_MODELS_PATH	"/usr/share/yang"
#define MODULE_PATH		"/usr/lib/$${MULTIARCH}/frr/modules"
#define SCRIPT_PATH		"/etc/frr/scripts"
#define SYSCONFDIR		"/etc/frr/"
#define VTYSH_BIN_PATH		"/usr/bin/vtysh"
#define WATCHFRR_SH_PATH	"/usr/lib/frr/watchfrr.sh"
EOF
""",
)

genrule(
    name = "version_h_gen",
    srcs = ["frr/lib/version.h.in"],
    outs = ["frr/lib/version.h"],
    cmd = r"""sed \
        -e 's|@PACKAGE_NAME@|frr|g' \
        -e 's|@PACKAGE_VERSION@|10.5.4|g' \
        -e 's|@PACKAGE_BUGREPORT@|https://github.com/frrouting/frr/issues|g' \
        -e 's|@CONFIG_ARGS@|(bazel build)|g' \
        -e 's|@configure_input@|version.h: bazel-generated from version.h.in|g' \
        $< > $@""",
)

# route_types.h -- Perl-generated; --enabled flags for every daemon whose
# HAVE_*D is set in config.h (mirrors the rt_enabled block in lib/subdir.am).
genrule(
    name = "route_types_h_gen",
    srcs = [
        "frr/lib/route_types.txt",
        "frr/lib/route_types.pl",
    ],
    outs = ["frr/lib/route_types.h"],
    cmd = r"""perl $(location frr/lib/route_types.pl) \
        --enabled babeld --enabled bfdd --enabled bgpd \
        --enabled eigrpd --enabled isisd --enabled fabricd \
        --enabled ldpd --enabled nhrpd --enabled ospfd \
        --enabled ospf6d --enabled pbrd --enabled pimd \
        --enabled ripd --enabled ripngd --enabled sharpd \
        --enabled staticd --enabled pathd --enabled vrrpd \
        --enabled zebra \
        < $(location frr/lib/route_types.txt) > $@""",
)

# vtysh_daemons.h -- in 10.5.4 libfrr (log_cli.c/log_vty.c) AND vtysh consume
# this, so it lands under lib/.
vtysh_daemons_h_genrule(
    name = "vtysh_daemons_h_gen",
    daemons = [
        "zebra",
        "bgpd",
        "ripd",
        "ripngd",
        "ospfd",
        "ospf6d",
        "ldpd",
        "nhrpd",
        "eigrpd",
        "babeld",
        "isisd",
        "pimd",
        "pim6d",
        "pbrd",
        "pathd",
        "bfdd",
        "vrrpd",
        "staticd",
        "fabricd",
        "sharpd",
        "mgmtd",
    ],
    outname = "frr/lib/vtysh_daemons.h",
)

# =============================================================================
# Header-view libraries for libfrr / clippy.
# =============================================================================

filegroup(
    name = "frr_lib_headers",
    srcs = glob(
        ["frr/lib/**/*.h"],
        exclude = ["frr/lib/version.h", "frr/lib/config_paths.h"],
    ) + [
        ":config_h_gen",
        ":config_paths_h_gen",
        ":version_h_gen",
        ":route_types_h_gen",
        ":vtysh_daemons_h_gen",
    ],
)

cc_library(
    name = "frr_lib_hdrs",
    hdrs = [":frr_lib_headers"],
    includes = [
        "frr",
        "frr/lib",
    ],
    visibility = ["//visibility:public"],
)

# FRR's lib/memory.h etc. shadow libc /usr/include/memory.h; expose FRR's own
# lib/*.h through strip_include_prefix so they win via _virtual_includes.
cc_library(
    name = "frr_lib_v_hdrs",
    hdrs = glob(
        ["frr/lib/**/*.h"],
        exclude = ["frr/lib/version.h", "frr/lib/config_paths.h"],
    ) + [
        ":version_h_gen",
        ":route_types_h_gen",
        ":vtysh_daemons_h_gen",
    ],
    strip_include_prefix = "frr/lib",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "frr_assert_hdrs",
    hdrs = glob(["frr/lib/assert/*.h"]),
    strip_include_prefix = "frr/lib/assert",
    visibility = ["//visibility:public"],
)

# Vendored Linux UAPI headers (include/linux/*.h) that shadow the toolchain's
# linux-libc-dev.  Placed FIRST in zebra deps.
cc_library(
    name = "frr_uapi_hdrs",
    hdrs = glob(["frr/include/**/*.h"]),
    strip_include_prefix = "frr/include",
    visibility = ["//visibility:public"],
)

# All FRR headers under the repo root exposed flat so `<lib/foo.h>`,
# `<bgpd/bgp_vty.h>`, `<zebra/foo.h>`, `<config.h>`, etc. resolve through one
# -I (via strip_include_prefix = repo root).
cc_library(
    name = "frr_v_hdrs",
    hdrs = glob(
        [
            "frr/lib/**/*.h",
            "frr/bfdd/*.h",
            "frr/bgpd/**/*.h",
            "frr/zebra/**/*.h",
            "frr/ospfd/*.h",
            "frr/ospf6d/*.h",
            "frr/isisd/*.h",
            "frr/pimd/*.h",
            "frr/fpm/*.h",
            "frr/qpb/*.h",
            "frr/nhrpd/*.h",
        ],
        exclude = ["frr/lib/version.h", "frr/lib/config_paths.h"],
    ) + [
        ":config_h_gen",
        ":config_paths_h_gen",
        ":version_h_gen",
        ":route_types_h_gen",
        ":vtysh_daemons_h_gen",
    ],
    strip_include_prefix = "frr",
    visibility = ["//visibility:public"],
)

# =============================================================================
# Bison / Flex generated command parser / lexers.
# Strip the upstream %output / %defines / %option outfile directives which
# hardcode a lib/ subdir that doesn't exist in the flex/bison sandbox.
# =============================================================================
genrule(
    name = "command_parse_y_stripped",
    srcs = ["frr/lib/command_parse.y"],
    outs = ["frr/lib/command_parse_stripped.y"],
    cmd = r"""sed -e '/^%defines/d' -e '/^%output/d' $< > $@""",
)

genrule(
    name = "command_lex_l_stripped",
    srcs = ["frr/lib/command_lex.l"],
    outs = ["frr/lib/command_lex_stripped.l"],
    cmd = r"""sed \
        -e '/^%option outfile/d' \
        -e '/^%option header-file/d' \
        -e '/^%option prefix/d' \
        $< > $@""",
)

genrule(
    name = "defun_lex_l_stripped",
    srcs = ["frr/lib/defun_lex.l"],
    outs = ["frr/lib/defun_lex_stripped.l"],
    cmd = r"""sed \
        -e '/^%option outfile/d' \
        -e '/^%option prefix/d' \
        $< > $@""",
)

bison(
    name = "frr/lib/command_parse",
    src = ":command_parse_y_stripped",
    bison_options = ["-Dapi.prefix={cmd_yy}"],
)

flex(
    name = "frr/lib/command_lex",
    src = ":command_lex_l_stripped",
    flex_options = ["-Pcmd_yy"],
)

flex(
    name = "frr/lib/defun_lex",
    src = ":defun_lex_l_stripped",
    flex_options = ["-Pdef_yy"],
)

# =============================================================================
# clippy build tool (lib_clippy_SOURCES from lib/subdir.am).
# =============================================================================

# FRR 10.5.4's lib/command_graph.c + lib/memory.c (both compiled into clippy)
# call _zlog_assert_failed() via the assert() macro in lib/assert/assert.h.
# That symbol lives in lib/zlog.c, which clippy does NOT link (clippy is a
# minimal host tool -- lib_clippy_SOURCES omits zlog.c).  clippy.c provides
# stubs for vzlogx()/memory_oom() but not this one, so supply a tiny abort()
# stub via a Bazel-generated TU (no source-tree edits).
genrule(
    name = "clippy_assert_stub_gen",
    outs = ["frr/lib/clippy_assert_stub.c"],
    cmd = r"""cat > $@ <<'EOF'
/* Bazel-generated clippy assert stub (see BUILD.bazel comment). */
#include <stdlib.h>
#include <stdarg.h>

struct xref_assert;

void _zlog_assert_failed(const struct xref_assert *xref, const char *extra, ...);
void _zlog_assert_failed(const struct xref_assert *xref, const char *extra, ...)
{
	abort();
}
EOF
""",
)

# Bare cc_import of JUST the trixie libelf .so file -- NO deps -- so the
# exec-cfg clippy tool doesn't drag in the target trixie libc6/ld-linux (which
# would clash with the host loader's libm at clippy runtime).  gcc records
# DT_NEEDED from the .so's SONAME (libelf.so.1); the host loader then resolves
# libelf via its default search path.  Only clippy uses this; all target-cfg
# consumers of libelf use the full @frr_deps//libelf-dev:libelf graph.
cc_import(
    name = "clippy_libelf_link",
    shared_library = "@@rules_distroless++apt+trixie_libelf1t64-amd64_0.192-4//:usr/lib/x86_64-linux-gnu/libelf.so.1",
    visibility = ["//visibility:private"],
)

cc_binary(
    name = "clippy",
    srcs = [
        "frr/lib/clippy.c",
        "frr/lib/command_graph.c",
        "frr/lib/command_py.c",
        "frr/lib/elf_py.c",
        "frr/lib/graph.c",
        "frr/lib/jhash.c",
        "frr/lib/libfrr_trace.c",
        "frr/lib/memory.c",
        "frr/lib/typesafe.c",
        "frr/lib/vector.c",
        ":clippy_assert_stub_gen",
        ":frr/lib/command_parse",
        ":frr/lib/command_lex",
        ":frr/lib/defun_lex",
    ],
    copts = [
        "-D_GNU_SOURCE",
        "-DBUILDING_CLIPPY",
        "-DHAVE_CONFIG_H",
        "-std=gnu11",
        "-fms-extensions",
        "-Wno-sign-compare",
        "-Wno-implicit-fallthrough",
        "-Wno-unused-but-set-variable",
        "-Wno-unused-function",
        "-Wno-misleading-indentation",
    ],
    deps = [
        ":frr_assert_hdrs",
        ":frr_lib_v_hdrs",
        ":frr_v_hdrs",
        ":frr_lib_hdrs",
        # libpython3.11 + Python C API via rules_python's hermetic toolchain.
        "@rules_python//python/cc:current_py_cc_libs",
        "@rules_python//python/cc:current_py_cc_headers",
        # elf_py.c CALLS libelf; link the bare .so directly (see comment above
        # on :clippy_libelf_link) + headers-only view.  We deliberately AVOID
        # @frr_deps//libelf-dev:libelf because it transitively cc_imports the
        # trixie libc6 / ld-linux, which would plant the target sysroot libc
        # in this exec-cfg host tool's RPATH and clash with the host libm.
        ":clippy_libelf_link",
        "@@rules_distroless++apt+trixie_libelf-dev-amd64_0.192-4//:libelf_hdrs",
        # zebra.h drags in <sys/capability.h>, <json-c/json.h>, <openssl/evp.h>
        # transitively; clippy only needs the headers, never the .so.
        "@@rules_distroless++apt+trixie_libcap-dev-amd64_1-2.75-10-b8//:libcap_hdrs",
        "@@rules_distroless++apt+trixie_libjson-c-dev-amd64_0.18-ds-1//:libjson-c_hdrs",
        "@@rules_distroless++apt+trixie-security_libssl-dev-amd64_3.5.5-1_deb13u2//:libssl_hdrs",
    ],
    linkopts = [
        "-Wl,--export-dynamic",
        "-lpthread",
        "-lm",
        # libelf .so was packaged against libz; we link it via the bare
        # cc_import (no transitive deps) so let ld skip verifying those refs --
        # the host loader pulls libz in via libelf.so.1's own NEEDED at runtime.
        "-Wl,--unresolved-symbols=ignore-in-shared-libs",
    ],
    visibility = ["//visibility:public"],
)

