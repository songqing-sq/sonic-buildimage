# libfrrospfapiclient.so.0 (ospfclient/libfrrospfapiclient.la).
#
# ospfclient/subdir.am (OSPFCLIENT true via --enable-ospfapi):
#   ospfclient_libfrrospfapiclient_la_LDFLAGS = -version-info 0:0:0
#   ospfclient_libfrrospfapiclient_la_LIBADD  = lib/libfrr.la
#   ospfclient_libfrrospfapiclient_la_SOURCES = ospfclient/ospf_apiclient.c
# -version-info 0:0:0 -> SONAME libfrrospfapiclient.so.0, real .so.0.0.0.
#
# ospf_apiclient.c references msg_*/new_msg_* helpers that live in ospfd's
# libfrrospfclient.a (ospf_api.c); the Make-built shipped .so leaves them
# UNDEFINED (verified via `readelf --dyn-syms` on the baseline), so we link
# with allow_undefined=True and do NOT drag in the ospfd api objects.
# =============================================================================
cc_library(
    name = "ospfclient_v_hdrs",
    hdrs = glob(["frr/ospfclient/*.h"]),
    strip_include_prefix = "frr/ospfclient",
    visibility = ["//visibility:private"],
)

sonic_shared_library_versioned(
    name = "libfrrospfapiclient",
    srcs = ["frr/ospfclient/ospf_apiclient.c"],
    copts = FRR_COMMON_COPTS + ["-fPIC"],
    deps = [
        ":ospfclient_v_hdrs",
