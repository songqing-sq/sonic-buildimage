    depends = [
        "libboost-filesystem1.83.0 (>= 1.83.0)",
        "libboost-program-options1.83.0 (>= 1.83.0)",
        "libboost-thread1.83.0 (>= 1.83.0)",
        "libc6 (>= 2.38)",
        "libgcc-s1 (>= 3.0)",
        "libgmp10 (>= 2:6.3.0+dfsg)",
        "libgrpc++1.51t64 (>= 1.51.1)",
        "libgrpc29t64 (>= 1.51.1)",
        "libnanomsg5 (>= 1.1.5)",
        "libpcap0.8t64 (>= 1.5.1)",
        "libprotobuf32t64 (>= 3.21.12)",
        "libstdc++6 (>= 14)",
        "libthrift-0.19.0t64 (>= 0.19.0-1~)",
        "p4lang-pi (>= 0.1.1)",
        "python3:any",
        "libtool",
        "pkg-config",
        "protobuf-compiler",
        "protobuf-compiler-grpc",
        "python3-thrift",
        "thrift-compiler",
    ],
)
