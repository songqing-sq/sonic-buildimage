# wpa_supplicant — the whole point of Approach B: built WITH macsec_sonic
# (sonic_operators.cpp + driver_macsec_sonic.c) linking libswsscommon.
cc_binary(
    name = "wpa_supplicant",
    srcs = WPA_SUPPLICANT_SRCS,
    copts = WPA_COPTS,
    linkopts = [
        "-Wl,--as-needed",
        "-lrt",
        "-lm",
    ],
    dynamic_deps = [
        "@sonic-swss-common//:swsscommon_shared",
        "@libnl3//:libnl_3_shared",
        "@libnl3//:libnl_genl_3_shared",
        "@libnl3//:libnl_route_3_shared",
        "@libnl3//:libnl_nf_3_shared",
        "@libyang3//:yang_shared",
    ],
    deps = [
        ":wpa_headers",
        "@sonic-swss-common//:swsscommon",
        "@libnl3//:libnl_3",
        "@libnl3//:libnl_genl_3",
        "@libnl3//:libnl_route_3",
        "@wpa_deps//libssl-dev:libssl",
        "@wpa_deps//libdbus-1-dev:libdbus-1",
        # Use the :pcsclite cc_import (libpcsclite.so.1 + headers) only. The
        # aggregate :libpcsclite cc_library also deps :pcscspy, which over-links
        # libpcscspy.so.0 (an extra DT_NEEDED absent from the Make baseline and
        # not shipped in the image). Make links only libpcsclite via pkg-config.
        "@wpa_deps//libpcsclite-dev:pcsclite",
    ],
)

cc_binary(
    name = "wpa_cli",
    srcs = [
        SRC + "/wpa_supplicant/wpa_cli.c",
        SRC + "/src/common/wpa_ctrl.c",
        SRC + "/src/utils/wpa_debug.c",
        SRC + "/src/utils/common.c",
        SRC + "/src/common/cli.c",
        SRC + "/src/utils/os_unix.c",
        SRC + "/src/utils/eloop.c",
        SRC + "/src/utils/edit_readline.c",
    ],
    copts = WPA_COPTS,
    linkopts = [
        "-Wl,--as-needed",
        "-lrt",
    ],
    deps = [
        ":wpa_headers",
        "@wpa_deps//libreadline-dev:libreadline",
        # readline links libtinfo (terminfo) — use the clean :tinfo cc_import.
        # The aggregate :libncurses target is broken in this rules_distroless
        # version (references undefined :curses / :termcap virtual provides).
        "@wpa_deps//libncurses-dev:tinfo",
    ],
)

