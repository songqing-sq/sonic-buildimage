# =============================================================================
# ifupdown / ifplugd integration symlinks (debian/wpasupplicant.links). The
# Make .deb ships these as relative symlinks; distroless runs no maintainer
# scripts, so they are materialised here and placed into the data tar via
# sonic_deb content (SymlinkInfo -> mtree type=link). Unique output subdirs
# avoid artifact-name collisions; the wildcard content key uses the basename.
# =============================================================================
symlink_to_path(
    name = "link_if_pre_up",
    output = "links/if-pre-up.d/wpasupplicant",
    target_path = "../../wpa_supplicant/ifupdown.sh",
)

symlink_to_path(
    name = "link_if_up",
    output = "links/if-up.d/wpasupplicant",
    target_path = "../../wpa_supplicant/ifupdown.sh",
)

symlink_to_path(
    name = "link_if_down",
    output = "links/if-down.d/wpasupplicant",
    target_path = "../../wpa_supplicant/ifupdown.sh",
)

symlink_to_path(
    name = "link_if_post_down",
    output = "links/if-post-down.d/wpasupplicant",
    target_path = "../../wpa_supplicant/ifupdown.sh",
)

symlink_to_path(
    name = "link_ifplugd_action_wpa",
    output = "links/ifplugd/action_wpa",
    target_path = "../../wpa_supplicant/action_wpa.sh",
)

