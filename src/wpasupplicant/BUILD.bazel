    name = "wpa_passphrase",
    srcs = [
        SRC + "/wpa_supplicant/wpa_passphrase.c",
        SRC + "/src/utils/common.c",
        SRC + "/src/utils/wpa_debug.c",
        SRC + "/src/utils/wpabuf.c",
        SRC + "/src/utils/os_unix.c",
        SRC + "/src/crypto/crypto_openssl.c",
        SRC + "/src/crypto/sha1-prf.c",
        SRC + "/src/crypto/sha1-tprf.c",
        SRC + "/src/crypto/sha1-tlsprf.c",
        SRC + "/src/crypto/sha256-prf.c",
        SRC + "/src/crypto/sha256-tlsprf.c",
    ],
    copts = WPA_COPTS,
    linkopts = [
        "-Wl,--as-needed",
        "-lrt",
    ],
    deps = [
        ":wpa_headers",
        "@wpa_deps//libssl-dev:libssl",
    ],
)

# =============================================================================
# Data files. systemd/dbus service files are generated from *.in templates by
# the upstream Makefile via `sed -e 's|@BINDIR@|/sbin|g'` (see
# wpa_supplicant/Makefile %.service / %@.service rules); BINDIR=/sbin comes from
# debian/rules. We replicate that sed substitution here.
# =============================================================================
[
    genrule(
        name = "gen_" + out.replace("@", "_at_").replace(".", "_"),
        srcs = [SRC + "/wpa_supplicant/systemd/" + tin],
        outs = [out],
        cmd = "sed -e 's|@BINDIR@|/sbin|g' $< > $@",
    )
    for (tin, out) in [
        ("wpa_supplicant.service.in", "wpa_supplicant.service"),
        ("wpa_supplicant.service.arg.in", "wpa_supplicant@.service"),
        ("wpa_supplicant-nl80211.service.arg.in", "wpa_supplicant-nl80211@.service"),
        ("wpa_supplicant-wired.service.arg.in", "wpa_supplicant-wired@.service"),
    ]
]

genrule(
    name = "gen_fi_service",
    srcs = [SRC + "/wpa_supplicant/dbus/fi.w1.wpa_supplicant1.service.in"],
    outs = ["fi.w1.wpa_supplicant1.service"],
    cmd = "sed -e 's|@BINDIR@|/sbin|g' $< > $@",
)

# The dbus system.d policy ships under a different basename than its source
# (debian/rules override_dh_install installs dbus-wpa_supplicant.conf as
# etc/dbus-1/system.d/wpa_supplicant.conf). sonic_deb can't rename, so copy.
genrule(
    name = "gen_dbus_conf",
    srcs = [SRC + "/wpa_supplicant/dbus/dbus-wpa_supplicant.conf"],
    outs = ["wpa_supplicant.conf"],
    cmd = "cp $< $@",
)

# Debian changelog, gzipped -9n for reproducibility (dh_installchangelogs).
genrule(
    name = "gen_changelog_deb",
    srcs = [SRC + "/debian/changelog"],
    outs = ["changelog.Debian.gz"],
    cmd = "gzip -9nc $< > $@",
)

filegroup(
    name = "systemd_services",
    srcs = [
        ":wpa_supplicant.service",
        ":wpa_supplicant@.service",
        ":wpa_supplicant-nl80211@.service",
        ":wpa_supplicant-wired@.service",
    ],
)

# =============================================================================
# wpasupplicant .deb — layout mirrors the Make baseline
# (target/debs/trixie/wpasupplicant_2.9.0-14_amd64.deb): binaries in /sbin +
# /usr/bin, ifupdown/dbus/systemd/NetworkManager/pm-utils data under /etc,
# /lib/systemd, /usr/lib, /usr/share. Version keeps the SONiC epoch (2:) — the
# .deb *filename* drops the epoch (wpasupplicant_2.9.0-14_<arch>.deb) exactly as
# the Make build does.
# =============================================================================
sonic_deb(
    name = "wpasupplicant_{}.deb".format(VERSION),
    package = "wpasupplicant",
    version = "2:" + VERSION,
    architecture = select({
        "@platforms//cpu:x86_64": "amd64",
        "@platforms//cpu:aarch64": "arm64",
    }),
    content = {
        "/sbin:*:0755": [
            ":wpa_supplicant",
            ":wpa_cli",
            SRC + "/debian/ifupdown/wpa_action",
        ],
        "/usr/bin:*:0755": [":wpa_passphrase"],
        "/etc/dbus-1/system.d:*:0644": [":gen_dbus_conf"],
        "/etc/wpa_supplicant:*:0755": [
            SRC + "/debian/ifupdown/action_wpa.sh",
            SRC + "/debian/ifupdown/wpasupplicant/ifupdown.sh",
        ],
        "/etc/wpa_supplicant:*:0644": [
            SRC + "/debian/ifupdown/functions.sh",
        ],
        "/lib/systemd/system:*:0644": [":systemd_services"],
        "/usr/share/dbus-1/system-services:*:0644": [":gen_fi_service"],
        "/usr/lib/NetworkManager/conf.d:*:0644": [
            SRC + "/debian/NetworkManager/no-mac-addr-change.conf",
        ],
        "/usr/lib/pm-utils/sleep.d:*:0755": [
            SRC + "/wpa_supplicant/examples/60_wpa_supplicant",
        ],
        "/usr/share/doc/wpasupplicant:*:0644": [
            SRC + "/debian/copyright",
            ":gen_changelog_deb",
        ],
        # ifupdown / ifplugd integration symlinks (debian/wpasupplicant.links).
        "/etc/network/if-pre-up.d:*:0777": [":link_if_pre_up"],
        "/etc/network/if-up.d:*:0777": [":link_if_up"],
        "/etc/network/if-down.d:*:0777": [":link_if_down"],
        "/etc/network/if-post-down.d:*:0777": [":link_if_post_down"],
        "/etc/ifplugd/action.d:*:0777": [":link_ifplugd_action_wpa"],
    },
    depends = [
        "libc6 (>= 2.34)",
        "libdbus-1-3 (>= 1.10)",
        "libgcc-s1 (>= 3.0)",
        "libnl-3-200 (>= 3.7.0-0.2+b1sonic1)",
        "libnl-genl-3-200 (>= 3.7.0-0.2+b1sonic1)",
        "libnl-route-3-200 (>= 3.7.0-0.2+b1sonic1)",
        "libpcsclite1 (>= 1.0.0)",
        "libreadline8t64 (>= 6.0)",
        "libssl3t64 (>= 3.0.0)",
        "libstdc++6 (>= 13.1)",
        "libswsscommon (>= 1.0.0)",
        "lsb-base",
        "adduser",
    ],
    suggests = [
        "wpagui",
        "libengine-pkcs11-openssl",
    ],
    breaks = [
        "initscripts (<< 2.88dsf-13.3)",
    ],
    multi_arch = "foreign",
    maintainer = "Debian wpasupplicant Maintainers <wpa@packages.debian.org>",
    description = "client support for WPA and WPA2 (IEEE 802.11i)\n WPA and WPA2 are methods for securing wireless networks, the former\n using IEEE 802.1X, and the latter using IEEE 802.11i. This software\n provides key negotiation with the WPA Authenticator, and controls\n association with IEEE 802.11i networks.",
    section = "net",
    priority = "optional",
    homepage = "https://w1.fi/wpa_supplicant/",
    gen_dbg = True,
    visibility = ["//visibility:public"],
)
