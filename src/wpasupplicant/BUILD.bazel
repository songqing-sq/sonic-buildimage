# -Werror is intentionally NOT propagated: the Make build adds it (via
# CONFIG_EAPOL_TEST) together with trixie gcc-14's -Wno-* escape hatches, but
# the hermetic toolchain here is a different gcc whose warning set differs.
# Warnings-as-errors would break the build on benign new diagnostics without
# changing the emitted code. We keep -Wall + the same -Wno-* set the Make
# recipe uses (debian/rules DEB_CFLAGS_MAINT_APPEND) so behaviour matches.
WPA_WARN_COPTS = [
    "-Wall",
    "-Wno-error",
    "-Wno-deprecated-declarations",
    "-Wno-use-after-free",
    "-Wno-discarded-qualifiers",
    "-Wno-array-bounds",
    "-Wno-unused-parameter",
    "-Wno-unused-variable",
    "-Wno-unused-but-set-variable",
    "-Wno-sign-compare",
]

WPA_COPTS = WPA_WARN_COPTS + WPA_DEFINES

# wpa's own headers. `includes` mirrors the Make compile's search path: the
# recipe runs from wpa_supplicant/ (=> "." on the quote path) with -I<abs>/src
# and -I<abs>/src/utils. Same-directory quote includes resolve via gcc's
# implicit current-file-dir search.
cc_library(
    name = "wpa_headers",
    hdrs = glob([
        SRC + "/src/**/*.h",
        SRC + "/wpa_supplicant/**/*.h",
    ]),
    includes = [
        SRC + "/src",
        SRC + "/src/utils",
        SRC + "/wpa_supplicant",
    ],
    visibility = ["//visibility:private"],
)

