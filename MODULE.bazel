# ---- Shared Go third-party hub for the sonic-mgmt-common / sonic-mgmt-framework
# module group. bzlmod only honors module_override/gazelle_override from the ROOT
# module, and a non-isolated go_deps instance is shared across the whole module
# graph. Declaring it here (instead of an isolated instance per submodule) gives
# both modules ONE set of third-party Go repos, so rest_server can link
# sonic-mgmt-common's translib/cvl alongside its own deps without hitting
# "multiple copies of package github.com/golang/glog". Version skews between the
# two go.mods (go-cmp, go-redis/v7) resolve via MVS to the higher (mgmt-common's)
# version, which is what mgmt-common already builds against.
go_deps = use_extension("@gazelle//:extensions.bzl", "go_deps")

# Root from_file carries the hub's replace pins (glog, gnmi -> the old versions
# mgmt-common's patch/build target). Only the root module's replaces are honored
# during shared-hub resolution; sonic-gnmi's go.mod requires newer glog/gnmi
# that would otherwise win via MVS and break the mgmt-common glog patch.
go_deps.from_file(go_mod = "//bazel/hub:go.mod")

# ygot.patch uses standard `a/generator/generator.go` paths (patch_strip=1).
# ytypes_build.patch is applied after gazelle generates BUILD files, adding the
# @com_github_openconfig_gnmi//value dep gazelle inconsistently dropped from
# ytypes/BUILD.bazel.
go_deps.module_override(
    path = "github.com/openconfig/ygot",
    patches = [
        "@sonic_mgmt_common//patches:ygot/ygot.patch",
        "@sonic_mgmt_common//patches:ytypes_build.patch",
    ],
    patch_strip = 1,
)
go_deps.module_override(
    path = "github.com/openconfig/goyang",
    patches = ["@sonic_mgmt_common//patches:goyang/goyang.patch"],
    patch_strip = 1,
)
go_deps.module_override(
    path = "github.com/antchfx/jsonquery",
    patches = ["@sonic_mgmt_common//patches:jsonquery.patch"],
    patch_strip = 1,
)
go_deps.module_override(
    path = "github.com/antchfx/xmlquery",
    patches = ["@sonic_mgmt_common//patches:xmlquery.patch"],
    patch_strip = 1,
)
go_deps.module_override(
    path = "github.com/antchfx/xpath",
    patches = ["@sonic_mgmt_common//patches:xpath.patch"],
    patch_strip = 1,
)
go_deps.module_override(
    path = "github.com/golang/glog",
    patches = ["@sonic_mgmt_common//patches:glog.patch"],
    patch_strip = 1,
)

# openconfig/gnmi ships pre-generated *.pb.go; disable proto rule generation so
# gazelle emits only a go_library over the checked-in .pb.go.
go_deps.gazelle_override(
    path = "github.com/openconfig/gnmi",
    directives = ["gazelle:proto disable_global"],
)

# openconfig/gnoi and gnsi (consumed by sonic-gnmi) also ship checked-in .pb.go;
# disable proto rules so gazelle doesn't pull rules_proto_grpc.
go_deps.gazelle_override(
    path = "github.com/openconfig/gnoi",
    build_file_generation = "clean",
    directives = ["gazelle:proto disable_global"],
)
go_deps.gazelle_override(
    path = "github.com/openconfig/gnsi",
    build_file_generation = "clean",
    directives = ["gazelle:proto disable_global"],
)

# grpc's authz -> internal/xds/rbac imports github.com/cncf/xds/go/{udpa/type/v1,
# xds/type/v3}. That module resolves to the BCR xds repo (bound to
# com_github_cncf_xds by grpc's C++ bazel_dep), which ships the .pb.go but no Go
# BUILD targets. Force gazelle to generate Go BUILDs so the grpc references
# resolve.
go_deps.gazelle_override(
    path = "github.com/cncf/xds/go",
    build_file_generation = "clean",
    directives = ["gazelle:proto disable_global"],
)

# msteinert/pam (gnmi_server PAM auth) has cgo but its gazelle BUILD only sets
# clinkopts=["-lpam"] with no header path. Patch it (after gazelle) to add a
# cdep on libpam0g-dev so <security/pam_appl.h> resolves and libpam links
# hermetically.
go_deps.module_override(
    path = "github.com/msteinert/pam",
    patches = ["@sonic_gnmi//patches/bazel:msteinert_pam_build.patch"],
    patch_strip = 1,
)

# advancedtls: gnmi_server/clientCertAuth.go calls advancedtls.CheckChainRevocation
# (exported by gnmi's Make patch 0002). Apply the same func-export rename here.
go_deps.module_override(
    path = "google.golang.org/grpc/security/advancedtls",
    patches = ["@sonic_gnmi//patches/bazel:advancedtls_go119.patch"],
    patch_strip = 1,
)

# fsnotify: telemetry.go uses fsnotify.CloseWrite / MovedTo, added by gnmi's Make
# patch 0004 onto fsnotify v1.4.9 (pinned in the hub go.mod).
go_deps.module_override(
    path = "github.com/fsnotify/fsnotify",
    patches = ["@sonic_gnmi//patches/bazel:fsnotify_closewrite.patch"],
    patch_strip = 1,
)

# The root's hub go.mod (//bazel/hub:go.mod) declares glog/gnmi/grpc/fsnotify as
# direct requires (to carry the replace pins); import them so gazelle's use_repo
# tidy check passes. Submodules import the repos they actually reference via
# their own use_repo against this shared instance.
use_repo(
    go_deps,
    "com_github_fsnotify_fsnotify",
    "com_github_golang_glog",
    "com_github_openconfig_gnmi",
    "org_golang_google_grpc",
)

# bitarray 2.8.1 (pinned by sonic-config-engine's install_requires) ships no
# cp313 wheel on PyPI (only up to cp311), so on trixie's Python 3.13 its C
# extensions must be compiled from source. We fetch the sdist here and build it
# with the project's hermetic GCC via cc rules in bitarray.BUILD, instead of
# aspect_rules_py's sdist_build (which uses the interpreter's clang sysconfig
# and a non-hermetic host compiler). Consumed by docker-config-engine-trixie.
http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "bitarray_src",
    build_file = "//dockers/docker-config-engine-trixie:bitarray.BUILD",
    sha256 = "e68ceef35a88625d16169550768fcc8d3894913e363c24ecbf6b8c07eb02c8f3",
    strip_prefix = "bitarray-2.8.1",
    urls = ["https://files.pythonhosted.org/packages/2b/22/b33fdaea9cb2de8a5b00b4b57bc91edef10c7e4aebec1f5c6235d501ba91/bitarray-2.8.1.tar.gz"],
)

# thrift 0.13.0 (pinned by docker-platform-monitor's `pip3 install thrift`) ships
# a pure-Python package plus an OPTIONAL C++ acceleration extension
# `thrift.protocol.fastbinary`. The aspect uv extension classified thrift as
# pure-Python (py3-none-any wheel) and never compiled fastbinary, so pmon would
# silently fall back to the slow pure-Python codec. We fetch the sdist here and
# compile fastbinary with the project's hermetic GCC via cc rules in
# thrift_fastbinary.BUILD (same approach as @bitarray_src), matching the Make
# image which builds it via setuptools. Consumed by docker-platform-monitor.
http_archive(
    name = "thrift_fastbinary_src",
    build_file = "//dockers/docker-platform-monitor:thrift_fastbinary.BUILD",
    sha256 = "9af1c86bf73433afc6010ed376a6c6aca2b54099cc0d61895f640870a9ae7d89",
    strip_prefix = "thrift-0.13.0",
    urls = ["https://files.pythonhosted.org/packages/97/1e/3284d19d7be99305eda145b8aa46b0c33244e4a496ec66440dac19f8274d/thrift-0.13.0.tar.gz"],
)

