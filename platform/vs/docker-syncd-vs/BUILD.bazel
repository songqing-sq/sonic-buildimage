# SONiC-built debs (Dockerfile.j2 `dpkg -i libnl-3-dev libnl-route-3-dev` +
# docker_<img>_debs). Both `_data` (file contents) and `_statusd` (distroless
# dpkg status.d stub) are included so `dpkg -l` lists each package inside the
# container, matching the Make image's package set.
#   @sonic-sairedis: syncd-vs (SYNCD_VS) + its RDEPENDS libsairedis / libsaimetadata
#                    / libsaivs. syncd-vs ships the syncd binary, syncd_start.sh,
#                    gbsyncdmgrd and companion tools under /usr/bin.
#   @libnl3:         SONiC-patched libnl-3-dev / libnl-route-3-dev (RTA_NH_ID
#                    netlink attribute patch). The runtime libnl-3-200 / -route-3-200
#                    .so.200 libs are already in the config-engine-trixie base.
#   @dash-sai:       libsai (DASH SAI pipeline: libsai.so + libdashsaimetadata.so),
#                    pulled in because INCLUDE_VS_DASH_SAI=y adds DASH_SAI to the
#                    syncd-vs deb RDEPENDS.
flatten(
    name = "sonic_pkgs",
    deduplicate = True,
    tars = [
        "@sonic-sairedis//:syncd-vs_1.0.0.deb_data",
        "@sonic-sairedis//:syncd-vs_1.0.0.deb_statusd",
        "@sonic-sairedis//:libsairedis_1.0.0.deb_data",
        "@sonic-sairedis//:libsairedis_1.0.0.deb_statusd",
        "@sonic-sairedis//:libsaimetadata_1.0.0.deb_data",
        "@sonic-sairedis//:libsaimetadata_1.0.0.deb_statusd",
        "@sonic-sairedis//:libsaivs_1.0.0.deb_data",
        "@sonic-sairedis//:libsaivs_1.0.0.deb_statusd",
        "@libnl3//:libnl-3-dev_3.7.0-0.2+b1sonic1.deb_data",
        "@libnl3//:libnl-3-dev_3.7.0-0.2+b1sonic1.deb_statusd",
        "@libnl3//:libnl-route-3-dev_3.7.0-0.2+b1sonic1.deb_data",
        "@libnl3//:libnl-route-3-dev_3.7.0-0.2+b1sonic1.deb_statusd",
        "@dash-sai//:libsai_1.0.0.deb_data",
        "@dash-sai//:libsai_1.0.0.deb_statusd",
    ],
)

# COPY directives (Dockerfile.j2). supervisord.conf references
# /usr/bin/supervisor-proc-exit-listener-rs, /usr/bin/syncd_start.sh (or
# /usr/bin/gbsyncdmgrd) and `python3 -m supervisord_dependent_startup`; those
# binaries come from the base image / the syncd-vs deb, not from this COPY.
tar(
    name = "files",
    srcs = [
        "start.sh",
        "supervisord.conf",
        "critical_processes",
    ],
    mtree = [
        "./usr/bin/start.sh uid=0 gid=0 mode=0755 type=file content=$(location :start.sh)",
        "./etc/supervisor/conf.d/supervisord.conf uid=0 gid=0 mode=0644 type=file content=$(location :supervisord.conf)",
        "./etc/supervisor/critical_processes uid=0 gid=0 mode=0644 type=file content=$(location :critical_processes)",
    ],
)

# config aligned to `docker inspect` of the Make image: Entrypoint=
# ["/usr/local/bin/supervisord"], Env adds DEBIAN_FRONTEND=noninteractive
# (PATH inherited from base), WorkingDir="/". The com.azure.sonic.* / Tag labels
# the Make build machinery injects via `docker build --label` are omitted (same
# accepted diff as docker-orchagent / docker-database / docker-teamd).
oci_image(
    name = "docker-syncd-vs",
    base = "//dockers/docker-config-engine-trixie:docker-config-engine-trixie",
    entrypoint = ["/usr/local/bin/supervisord"],
    env = {"DEBIAN_FRONTEND": "noninteractive"},
    workdir = "/",
    tars = [
        ":apt_layer",
        ":sonic_pkgs",
        ":files",
    ],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "load",
    image = "docker-syncd-vs",
    repo_tags = ["docker-syncd-vs:latest"],
)
