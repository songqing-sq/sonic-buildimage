# docker-dash-engine (platform/vs/docker-dash-engine.mk + Dockerfile.j2).
#
# Base is the upstream p4lang/behavioral-model image (Ubuntu 20.04.6), pulled
# via oci.pull in the root MODULE.bazel and digest-pinned (41e339b0) to the exact
# build the Make `:latest` resolved to (recovered from the Make build log). The
# Make Dockerfile.j2 final stage is `FROM scratch` + `COPY --from=base / /`, i.e.
# the whole base rootfs squashed plus the delta below.
#
# Delta relative to base (what the Make Dockerfile.j2 adds):
#   RUN apt install net-tools supervisor rsyslog python3-pip (+recommends)
#                                  -> :focal_pkgs layer (92 focal .debs)
#   COPY [start.sh, /usr/bin/]     -> /usr/bin/start.sh
#   ENTRYPOINT ["/usr/bin/start.sh"]
# (Phase 2 side-effects -- sonic-build-hooks / postinst symlinks / passwd /
# sources.list / .pyc strip -- are layered separately; see below.)

