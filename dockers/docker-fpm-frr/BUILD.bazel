# Make docker-fpm-frr final image config (docker inspect):
# Entrypoint=["/usr/bin/docker_init.sh"], Cmd=null, WorkingDir=/,
# Env adds DEBIAN_FRONTEND=noninteractive (PATH inherited from base).
oci_image(
    name = "docker-fpm-frr",
    base = "//dockers/docker-swss-layer-trixie:docker-swss-layer-trixie",
    entrypoint = ["/usr/bin/docker_init.sh"],
    env = {
        "DEBIAN_FRONTEND": "noninteractive",
    },
    workdir = "/",
    tars = [
        ":apt_layer",
        ":sonic_pkgs",
        ":python_layer",
        ":passwd",
        ":group",
        ":files",
    ],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "load",
    image = "docker-fpm-frr",
    repo_tags = ["docker-fpm-frr:latest"],
)
